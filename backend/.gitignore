# Dependencies
node_modules/

# Environment variables — contains real secrets, NEVER commit this
.env
.env.*
!.env.example

# Build output
dist/

# Prisma generated client — this gets regenerated from schema.prisma, no need to commit it
src/generated/

# Uploaded files — these are user data, shouldn't live in version control
uploads/

# Logs
*.log
npm-debug.log*

# OS-specific junk files
.DS_Store
Thumbs.db

# Editor-specific
.vscode/
.idea/